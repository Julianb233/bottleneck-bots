{
  "name": "bottleneck-bots",
  "version": "0.1.0",
  "description": "TypeScript SDK for Bottleneck Bots — cloud desktop environments for AI agents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": { "node": ">=22" },
  "dependencies": { "ws": "^8.18.0" },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "tsdown": "^0.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
